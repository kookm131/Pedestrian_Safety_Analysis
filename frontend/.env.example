# GEMINI_API_KEY: Gemini AI API 호출에 필요합니다.
# AI Studio는 실행 시 사용자 비밀 설정에서 이를 자동으로 주입합니다.
# 사용자는 AI Studio UI의 Secrets 패널을 통해 이를 설정할 수 있습니다.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: 이 애플릿이 호스팅되는 URL입니다.
# AI Studio는 실행 시 Cloud Run 서비스 URL로 이를 자동으로 주입합니다.
# 자기 참조 링크, OAuth 콜백 및 API 엔드포인트에 사용됩니다.
APP_URL="MY_APP_URL"
