# CAPS: Cloud-AI Pedestrian Safety Analysis Platform Configuration Example

# PostgreSQL Connection URL
POSTGRES_URL=postgresql://user:pass@db_postgres:5432/caps

# MongoDB Connection URL (GridFS)
MONGO_URL=mongodb://db_mongo:27017/caps

# RabbitMQ Connection URL
RABBITMQ_URL=amqp://user:password@rabbitmq:5672/

# Redis Connection URL
REDIS_URL=redis://redis:6379/0

# Strict Authentication Mode (true/false)
STRICT_AUTH=false

# AI Model Path (Optional)
# YOLO_MODEL_PATH=yolo11n.pt
